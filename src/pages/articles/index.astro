---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';

const articles = await getCollection('articles', ({ data }) => data.status === 'published');
const sorted = articles.sort((a, b) => +new Date(b.data.publishedAt) - +new Date(a.data.publishedAt));
const defaultAuthorSlug = (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || 'default-author';
---

<BaseLayout title="Articles" description="Practical, research-backed answers for midlife questions.">
  <section class="max-w-5xl mx-auto px-5 py-12">
    <h1 class="font-display text-4xl text-ink-900 mb-3">Articles</h1>
    <p class="text-ink-700 mb-10 max-w-prose">
      Short, specific answers to questions you actually search for. Each links back to the
      fuller guide on the topic.
    </p>

    {sorted.length === 0 && <p class="text-ink-700">First articles coming soon.</p>}

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map((a) => (
        <a href={`/articles/${a.slug}`} class="group no-underline block">
          {a.data.heroImage ? (
            <div class="rounded-lg overflow-hidden mb-3 bg-cream-200 aspect-[16/10]">
              <img
                src={a.data.heroImage}
                alt={a.data.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
          ) : (
            <div class="rounded-lg bg-cream-200 aspect-[16/10] mb-3"></div>
          )}
          <h2 class="font-display text-xl text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-500 transition-colors">
            {a.data.title}
          </h2>
          <p class="text-ink-700 mt-2 text-sm">{a.data.excerpt}</p>
          <div class="mt-3 flex items-center gap-2.5 text-xs text-ink-500">
            <img
              src={`/authors/${a.data.author ?? defaultAuthorSlug}.jpg`}
              alt={a.data.author ?? defaultAuthorSlug}
              class="w-8 h-8 rounded-full object-cover"
              loading="lazy"
            />
            <span>{new Date(a.data.publishedAt).toLocaleDateString()}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
